{
    "version": 2,
    "builds": [
        {
            "src": "frontend/package.json",
            "use": "@vercel/next"
        },
        {
            "src": "api/*.py",
            "use": "@vercel/python",
            "config": {
                "maxDuration": 30,
                "includeFiles": "*.csv"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/$1"
        }
    ]
}